rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Solução de Segurança: O portfólio precisa ser público (leitura livre),
    // mas a modificação do banco só pode ser feita por usuários/clientes logados.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // WhatsApp sessions - only the backend (admin SDK) can read/write
    match /whatsapp_sessions/{phoneNumber} {
      allow read, write: if false;
    }
    
    match /whatsapp_personal_contacts/{number} {
      allow read, write: if false;
    }
    
    // Leads - only the backend can create, William can read via admin panel
    match /leads/{leadId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
