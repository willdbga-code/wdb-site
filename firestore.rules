rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RESTAURAÇÃO DE EMERGÊNCIA: Permitir que clientes e admin acessem fotos e galerias
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // WhatsApp sessions - only the backend (admin SDK) can read/write
    match /whatsapp_sessions/{phoneNumber} {
      allow read, write: if false;
    }
    
    match /whatsapp_personal_contacts/{number} {
      allow read, write: if false;
    }
    
    // Leads - only the backend can create, William can read via admin panel
    match /leads/{leadId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
